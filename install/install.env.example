# =============================================================================
#  install.env.example — reference for the .env install.sh generates.
#
#  This file documents every variable the generated .env (and the dashboard's
#  .env.production) will contain. install.sh generates the real .env from flags
#  + auto-detection; you do NOT need to edit this file. It exists so operators
#  can see what's coming and pre-seed secrets via flags if they want.
#
#  Two files are emitted at staging time:
#    <staging>/.env                          — docker compose reads this
#    <staging>/vpn-dashboard-v3/.env.production — Next.js inlines at build time
# =============================================================================

# ── server identity (NEXT_PUBLIC_* are baked into the dashboard build) ──
NEXT_PUBLIC_SERVER_IP=203.0.113.10         # public IP clients dial (Reality/SS/HY2/WG)
SERVER_IP=203.0.113.10                     # same value, consumed by the Python API
NEXT_PUBLIC_SERVER_DOMAIN=vpn.example.com   # required for modes B, C
SERVER_DOMAIN=vpn.example.com
NEXT_PUBLIC_SERVER_PORT=443
SERVER_PORT=443
NEXT_PUBLIC_PUBLIC_BASE_URL=https://vpn.example.com/v3
NEXT_PUBLIC_BRAND_NAME=Archie VPN
BRAND_NAME=Archie VPN

# ── VLESS Reality (public values also baked into dashboard) ──
# Private key (reality_pvk) lives ONLY in xray config.json — never in .env.
VLESS_PBK=                                  # xray x25519 "Public key" (43-char base64url)
VLESS_SID=                                  # openssl rand -hex 8
VLESS_SNI=www.cloudflare.com                 # Reality decoy SNI
NEXT_PUBLIC_VLESS_PBK=
NEXT_PUBLIC_VLESS_SID=
NEXT_PUBLIC_VLESS_SNI=www.cloudflare.com

# ── secrets ──
AUTH_SECRET=                                # openssl rand -base64 32 (session cookie HMAC)
VPN_API_V3_TOKEN=                           # openssl rand -hex 32  (dashboard→API bearer)
ALLOWED_ORIGINS=https://vpn.example.com/v3  # CORS for the Python API

# ── protocol material ──
HYSTERIA_PASSWORD=                          # openssl rand -hex 16 (bootstrap operator password)
WG_SERVER_PUB=                              # wg pubkey (clients need this)

# ── paths (container-internal defaults; compose mounts host paths) ──
XRAY_CFG=/etc/xray/config.json
STATE_DIR=/app/vpn-api
DATA_DIR=/app/data
USER_META_FILE=/app/data/user_meta.json
WG_CLIENTS_FILE=/etc/wireguard/clients.json
VPN_API_INTERNAL_URL=http://vpn-api-v3:5900

# ── host log paths (mounted read-only into containers) ──
LOG_ACCESS=/var/log/xray/access.log
LOG_AUTH=/var/log/host/auth.log
LOG_F2B=/var/log/host/fail2ban.log
HOST_TCP6=/host_net/tcp6

# ── dashboard ──
NEXT_PUBLIC_BASE_PATH=/v3                   # next.config.ts hardcodes /v3 — do not change
NEXT_PUBLIC_SECURITY_PAGE_PATH=/security-review

# ── optional: AbuseIPDB ──
ABUSEIPDB_API_KEY=

# ── optional: Telegram alerts ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# ── optional: invite email (SMTP) ──
# Only emitted when --smtp-host is supplied. host + from = sendable. Operators
# can also set these later in Settings → Email delivery (stored override wins).
SMTP_HOST=                                  # e.g. smtp.gmail.com
SMTP_PORT=587                               # 465 = implicit TLS, 587 = STARTTLS
SMTP_SECURE=false                           # true for port 465
SMTP_USER=                                  # omit for unauthenticated relays
SMTP_PASS=                                  # app password / SMTP password
SMTP_FROM=                                  # "My VPN <invites@example.com>"
