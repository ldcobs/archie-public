# ─────────────────────────────────────────────────────────────────────────────
# Archie — environment template
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local (dashboard) and/or your docker-compose env_file, then fill
# in the values for YOUR deployment. Do NOT commit .env.local.
#
# Values shown are EXAMPLES / placeholders. The application also ships with
# built-in fallbacks for the server-identity vars so the reference deployment
# keeps working — but for a fresh install you MUST set the SERVER / VLESS vars
# below, otherwise your clients will be configured for someone else's server.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server identity (REQUIRED for a fresh install) ───────────────────────────
# These define where VPN clients connect. Get them wrong and every generated
# key will point at the wrong host.

# Public IP clients dial for direct protocols (VLESS Reality, Trojan, SS, H2).
NEXT_PUBLIC_SERVER_IP=203.0.113.10
SERVER_IP=203.0.113.10

# Public domain fronting the CDN/TLS protocols (VMess/VLESS/Trojan over WS/gRPC).
NEXT_PUBLIC_SERVER_DOMAIN=vpn.example.com
SERVER_DOMAIN=vpn.example.com

# Port the CDN/TLS protocols are served on (usually 443 behind Cloudflare/nginx).
NEXT_PUBLIC_SERVER_PORT=443
SERVER_PORT=443

# Full public base URL of the dashboard, INCLUDING the basePath if any.
# Used to build subscription URLs handed to clients.
NEXT_PUBLIC_PUBLIC_BASE_URL=https://vpn.example.com:8443/v3


# ── VLESS Reality keypair (REQUIRED for a fresh install) ──────────────────────
# Generate your own with:  xray x25519
# Do NOT reuse the reference deployment's values — they are public.
NEXT_PUBLIC_VLESS_PBK=
NEXT_PUBLIC_VLESS_SID=
NEXT_PUBLIC_VLESS_SNI=www.cloudflare.com
VLESS_PBK=
VLESS_SID=
VLESS_SNI=www.cloudflare.com


# ── Branding (optional) ──────────────────────────────────────────────────────
# Shown in the browser tab title and in subscription profile labels.
NEXT_PUBLIC_BRAND_NAME=My VPN
BRAND_NAME=My VPN


# ── Dashboard auth (REQUIRED for a fresh install) ─────────────────────────────
# Secret used to HMAC-sign operator session cookies. Generate a strong random
# value, e.g.:  openssl rand -base64 32
# If unset, a deterministic dev fallback is used — DO NOT ship that to prod.
AUTH_SECRET=


# ── Paths (optional — sensible defaults) ─────────────────────────────────────
# Where the live Xray config lives (mounted into the container).
XRAY_CFG=/etc/xray/config.json
# Where mutable state files live (device approvals, pending config, audit log).
STATE_DIR=/app/vpn-api
# Dev-only: where the dashboard reads sample data when the VPS files are absent.
DATA_DIR=
# Pending inbound config + audit log paths (safe-write flow).
PENDING_CFG=
PENDING_AUDIT=
XRAY_AUDIT=
# WireGuard clients config + user metadata file.
WG_CLIENTS_FILE=
USER_META_FILE=


# ── Dashboard routing (optional) ─────────────────────────────────────────────
# basePath the dashboard is served under (matches the nginx location + Docker).
NEXT_PUBLIC_BASE_PATH=/v3


# ── Python VPN API (optional) ────────────────────────────────────────────────
# Internal URL the dashboard uses to reach the Python API (container-to-container).
VPN_API_INTERNAL_URL=http://vpn-api-v3:5900
# Bearer token the Python API requires on mutating routes. Generate a strong one.
API_AUTH_TOKEN=
# CORS allow-list (comma-separated origins).
ALLOWED_ORIGINS=
# Path to the xray binary (for `xray run -test`). Mounted into vpn-api-v3.
XRAY_BIN=/usr/local/bin/xray


# ── Security enrichment (optional) ───────────────────────────────────────────
# AbuseIPDB API key for IP reputation lookups. Leave empty to disable enrichment.
ABUSEIPDB_API_KEY=


# ── Dev / sample data (do NOT set in production) ─────────────────────────────
# Forces the dashboard to serve mock data instead of live state. Dev only.
NEXT_PUBLIC_FORCE_SAMPLE_DATA=
FORCE_SAMPLE_DATA=
# Log file paths (server-side reads of auth.log etc.).
LOG_AUTH=/var/log/auth.log
LOG_ACCESS=/var/log/nginx/access.log
LOG_F=
HOST_TCP=

# ── Email delivery (SMTP) — invite-via-email ──────────────────────────────────
# When set, the dashboard can deliver invite links by email. These are defaults;
# an operator can override them in Settings → Email delivery (stored per-install).
# Leave blank to disable email delivery (operators still copy/QR the link).
SMTP_HOST=
SMTP_PORT=587
# true = implicit TLS (port 465); false = STARTTLS (587) or plain (25)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From header, e.g. "My VPN <invites@example.com>"
SMTP_FROM=
